FROM alpine:latest

RUN apk add vim git python3

RUN adduser -u 1001 -D user
USER 1001
RUN mkdir /home/user/interests-scraper
WORKDIR /home/user/interests-scraper

COPY internal/  /home/user/interests-scraper/internal
COPY website/  /home/user/interests-scraper/website
COPY __init__.py/  /home/user/interests-scraper/__init__.py
RUN python -m venv website-env && . website-env/bin/activate && pip install -r website/requirements.txt

EXPOSE 8000/tcp
ENV UI_PORT=8000 PSQL_HOST='' PSQL_DB=scraper PSQL_USER=u_reader PSQL_PASS='CHANGEME'
CMD ["/bin/sh", "-c", ". website-env/bin/activate ; python3 website/server.py"]
